{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noImplicitAny": false,
    "outDir": "./dist/server",
    "rootDir": ".",
    "sourceMap": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    "apps/server/src/**/*.ts",
    "packages/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "apps/web"
  ]
}
