{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orkestr Private Overlay",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "connectors": { "type": "object" },
    "executors": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "default": { "type": "string" },
        "modules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "agents": {
      "type": "array",
      "items": { "type": "object" }
    },
    "timers": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
