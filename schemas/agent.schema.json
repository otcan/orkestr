{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orkestr Agent",
  "type": "object",
  "required": ["id", "name"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "templateId": { "type": "string" },
    "connectors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "systemPrompt": { "type": "string" }
  }
}
