# Orkestr unattended installer config.
# Copy to ./orkestr.install.env and edit for unattended local installs.
# Do not commit the copied file.

ORKESTR_INSTALL_MODE=local
ORKESTR_HOST=127.0.0.1
ORKESTR_PORT=19812
ORKESTR_HOME=$HOME/.orkestr
ORKESTR_WORKSPACE_DIR=$HOME/.orkestr/workspaces
ORKESTR_START_AFTER_INSTALL=1

# Conservative Codex defaults: Orkestr can surface approval requests in the UI
# and through connected chat surfaces.
ORKESTR_CODEX_SANDBOX=workspace-write
ORKESTR_CODEX_APPROVAL_POLICY=on-request
ORKESTR_RUNTIME_CODEX_COMMAND="codex --sandbox workspace-write --ask-for-approval on-request --no-alt-screen"

# For a service install, use ORKESTR_INSTALL_MODE=service and run as root.
# ORKESTR_INSTALL_MODE=service
# ORKESTR_INSTALL_DIR=/opt/orkestr/app
# ORKESTR_HOME=/opt/orkestr/data
# ORKESTR_WORKSPACE_DIR=/opt/orkestr/workspace
# ORKESTR_RUN_USER=orkestr
# ORKESTR_AUTO_UPDATE=1
