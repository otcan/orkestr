# Orkestr public alpha configuration.
# Copy to .env for local development. Do not commit real secrets.

ORKESTR_HOST=127.0.0.1
ORKESTR_PORT=19812
ORKESTR_HOME=.orkestr
ORKESTR_RUNTIME_SETTINGS_FILE=.orkestr/runtime-settings.json

# Public URL used in browser-visible links when Orkestr is exposed.
ORKESTR_PUBLIC_HTTPS_URL=

# Optional public OAuth callback broker for external users, for example
# https://connect.orkestr.app. When set, OAuth connector callbacks use this
# public base instead of a private/local Orkestr URL.
ORKESTR_CONNECT_PUBLIC_URL=

# Optional private overlay directory. Keep real credentials, host-specific
# executors, browser profiles, personal prompts, and production bindings there.
ORKESTR_OVERLAY_DIR=

# Optional connector/runtime inputs.
OPENAI_API_KEY=
CODEX_HOME=
# WhatsApp uses Orkestr's integrated local bridge by default.
WHATSAPP_BRIDGE_MODE=local
# Legacy external bridge compatibility is disabled unless explicitly enabled by
# the host operator.
ORKESTR_WHATSAPP_EXTERNAL_BRIDGE_ENABLED=0
WHATSAPP_BRIDGE_URL=

# Optional Codex runtime controls for thread leases.
ORKESTR_CODEX_SANDBOX=workspace-write
ORKESTR_CODEX_APPROVAL_POLICY=on-request
ORKESTR_RUNTIME_CODEX_COMMAND=codex --sandbox workspace-write --ask-for-approval on-request --no-alt-screen
ORKESTR_RUNTIME_WORKSPACE_ROOT=
ORKESTR_RUNTIME_SUBMIT_KEYS=C-m
ORKESTR_RUNTIME_SUBMIT_DELAY_MS=250
ORKESTR_WAKE_READY_TIMEOUT_MS=60000
ORKESTR_BROWSER_DESKTOP_MODE=profiles
ORKESTR_DEFAULT_DESKTOP_SLUG=desktop
ORKESTR_GMAIL_AUTH_DESKTOP_SLUG=gmail
ORKESTR_MANUAL_INTERVENTION_DESKTOP_SLUG=desktop

# Optional parent-managed connector OAuth apps. These configure the app once;
# each user still connects their own account from chat.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=
# Production installs generate this automatically. Keep it outside ORKESTR_HOME.
ORKESTR_CONNECTOR_ENCRYPTION_KEY=
# The public verification profile is send-only. Use "all" only for a separately reviewed development client.
ORKESTR_GOOGLE_OAUTH_ALLOWED_CAPABILITIES=gmail_send
# Named profiles are optional; legacy GMAIL_OAUTH_* values remain the default.
ORKESTR_GOOGLE_OAUTH_DEFAULT_APP=default
ORKESTR_GOOGLE_OAUTH_APPS_JSON=
OUTLOOK_OAUTH_CLIENT_ID=
OUTLOOK_OAUTH_TENANT_ID=common
OUTLOOK_OAUTH_SCOPES=offline_access User.Read Mail.Read
JIRA_OAUTH_CLIENT_ID=
JIRA_OAUTH_CLIENT_SECRET=
JIRA_OAUTH_REDIRECT_URI=
JIRA_OAUTH_SCOPES=read:jira-user read:jira-work offline_access
SHOPIFY_OAUTH_CLIENT_ID=
SHOPIFY_OAUTH_CLIENT_SECRET=
SHOPIFY_OAUTH_REDIRECT_URI=
SHOPIFY_OAUTH_SCOPES=read_products,read_orders
