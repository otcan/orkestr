# Orkestr public alpha configuration.
# Copy to .env for local development. Do not commit real secrets.

ORKESTR_HOST=127.0.0.1
ORKESTR_PORT=19812
ORKESTR_HOME=.orkestr
ORKESTR_INSTALL_PROFILE=local-safe
ORKESTR_RUNTIME_SETTINGS_FILE=.orkestr/runtime-settings.json

# Optional private overlay directory. Keep real credentials, host-specific
# executors, browser profiles, personal prompts, and production bindings there.
ORKESTR_OVERLAY_DIR=

# Optional connector/runtime inputs.
OPENAI_API_KEY=
CODEX_HOME=
# WhatsApp uses Orkestr's integrated local bridge by default.
WHATSAPP_BRIDGE_MODE=local
# Legacy external bridge compatibility is disabled unless explicitly enabled by
# the host operator.
ORKESTR_WHATSAPP_EXTERNAL_BRIDGE_ENABLED=0
WHATSAPP_BRIDGE_URL=

# Optional Codex runtime controls for thread leases.
ORKESTR_CODEX_SANDBOX=workspace-write
ORKESTR_CODEX_APPROVAL_POLICY=on-request
ORKESTR_RUNTIME_CODEX_COMMAND=codex --sandbox workspace-write --ask-for-approval on-request --no-alt-screen
ORKESTR_RUNTIME_WORKSPACE_ROOT=
ORKESTR_RUNTIME_SUBMIT_KEYS=C-m
ORKESTR_RUNTIME_SUBMIT_DELAY_MS=250
ORKESTR_WAKE_READY_TIMEOUT_MS=60000
ORKESTR_BROWSER_DESKTOP_MODE=profiles
ORKESTR_DEFAULT_DESKTOP_SLUG=desktop
ORKESTR_GMAIL_AUTH_DESKTOP_SLUG=gmail
ORKESTR_MANUAL_INTERVENTION_DESKTOP_SLUG=desktop
