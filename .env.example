# Orkestr public alpha configuration.
# Copy to .env for local development. Do not commit real secrets.

ORKESTR_HOST=127.0.0.1
ORKESTR_PORT=19812
ORKESTR_HOME=.orkestr

# Optional private overlay directory. Keep real credentials, host-specific
# executors, browser profiles, personal prompts, and production bindings there.
ORKESTR_OVERLAY_DIR=

# Optional connector/runtime inputs.
OPENAI_API_KEY=
CODEX_HOME=
# WhatsApp uses Orkestr's integrated local bridge by default.
WHATSAPP_BRIDGE_MODE=local

# Optional Codex runtime controls for thread leases.
ORKESTR_RUNTIME_CODEX_COMMAND=codex --dangerously-bypass-approvals-and-sandbox
ORKESTR_RUNTIME_WORKSPACE_ROOT=
ORKESTR_RUNTIME_SUBMIT_KEYS=C-m
ORKESTR_RUNTIME_SUBMIT_DELAY_MS=250
ORKESTR_WAKE_READY_TIMEOUT_MS=60000
