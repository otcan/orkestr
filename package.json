{
  "name": "orkestr-oss",
  "version": "0.1.0",
  "description": "Local-first personal agent workstation: setup, connectors, virtual browsers, WhatsApp, and timers.",
  "type": "module",
  "bin": {
    "orkestr-oss": "./apps/cli/bin/orkestr-oss.js"
  },
  "scripts": {
    "start": "node apps/server/src/server.js",
    "dev": "node apps/server/src/server.js --open",
    "check": "find apps packages scripts examples -path '*/node_modules/*' -prune -o \\( -name '*.js' -o -name '*.mjs' \\) -print | while read -r file; do node --check \"$file\"; done && npm run web:build && node --test",
    "test": "node --test",
    "web:build": "ng build web",
    "smoke": "node scripts/smoke.mjs",
    "demo:job-search": "node scripts/job-search-demo.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "dependencies": {
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/router": "^21.2.13",
    "fastify": "^5.8.5",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.13",
    "typescript": "~5.9.3"
  }
}
