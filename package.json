{
  "name": "orkestr-oss",
  "version": "0.1.0-alpha.32",
  "description": "Self-hosted agent workstation: Codex threads, connectors, virtual browsers, WhatsApp, and timers.",
  "type": "module",
  "bin": {
    "orkestr": "./apps/cli/bin/orkestr-oss.js",
    "orkestr-oss": "./apps/cli/bin/orkestr-oss.js"
  },
  "scripts": {
    "start": "node dist/server/apps/server/src/server.js",
    "dev": "npm run build && node dist/server/apps/server/src/server.js --open",
    "build:server": "tsc -p tsconfig.server.json",
    "build:runtime": "bash scripts/build-runtime.sh",
    "build": "npm run build:server && npm run web:build",
    "web:verify-static": "node scripts/verify-static-web.mjs",
    "check": "find apps packages scripts examples -path '*/node_modules/*' -prune -o \\( -name '*.js' -o -name '*.mjs' \\) -print | while read -r file; do node --check \"$file\"; done && npm run build && node --test",
    "test": "node --test",
    "test:ci": "node scripts/ci-test-runner.mjs",
    "oss:boundary-check": "node scripts/oss-boundary-check.mjs",
    "deploy:split-plan": "node scripts/deployment-split-plan.mjs",
    "secrets:migrate-env": "node scripts/secure-secrets-migrate-env.mjs",
    "test:tenant-isolation": "node --test test/use-control.test.js test/security.test.js test/checks.test.js test/gmail.test.js test/outlook.test.js test/browsers.test.js test/codex-app-server.test.js test/whatsapp.test.js test/whereiam.test.js test/tenant-vm-registry.test.js test/tenant-vm-provisioning.test.js test/tenant-whatsapp-routing.test.js",
    "release:regression": "node scripts/release-regression.mjs",
    "e2e:whatsapp-real": "node scripts/real-wa-e2e.mjs",
    "web:build": "ng build web",
    "smoke": "node scripts/smoke.mjs",
    "smoke:public-domain": "bash scripts/smoke-public-domain.sh",
    "smoke:public-kubevirt": "bash scripts/migrate-public-kubevirt.sh smoke",
    "smoke:vps:aws": "bash scripts/smoke-vps-aws.sh",
    "smoke:vps:k3s": "bash scripts/smoke-vps-k3s.sh",
    "smoke:k3s:oss-demo": "node scripts/smoke-k3s-oss-demo.mjs",
    "smoke:demo-vm": "node --test test/demo-vm-bootstrap.test.js",
    "k3s:public-ip": "bash scripts/k3s-vm-public-ip.sh",
    "install:local": "bash scripts/install.sh",
    "demo:coding-agent": "node scripts/coding-agent-demo.mjs",
    "demo:record": "node scripts/record-demo.mjs",
    "launch:check": "node scripts/launch-check.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "whatsapp-web.js": "^1.34.7",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/compiler-cli": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/router": "^21.2.13",
    "@types/node": "^25.8.0",
    "@types/ws": "^8.18.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "zone.js": "^0.16.2"
  },
  "overrides": {
    "qs": "6.15.2"
  }
}
