# Orkestr Docker settings.
# Copy this file to .env next to docker-compose.yml and edit local values.
# Do not commit a filled .env file.

# Image/runtime.
ORKESTR_IMAGE=ghcr.io/otcan/orkestr:latest
ORKESTR_PULL_POLICY=missing
ORKESTR_BIND_ADDRESS=127.0.0.1
ORKESTR_PUBLISH_PORT=19812
ORKESTR_WORKSPACE_HOST_DIR=./workspace
ORKESTR_OVERLAY_HOST_DIR=./examples/private-overlay
ORKESTR_INSTALL_PROFILE=local-safe
ORKESTR_RUNTIME_SETTINGS_FILE=/data/runtime-settings.json
# Leave empty to infer from ORKESTR_BIND_ADDRESS. Set 1 when a host-managed
# reverse proxy exposes the app while Docker publishes only to localhost.
ORKESTR_REVERSE_PROXY_LOCAL_BIND=

# Public/remote access. Keep auth enabled when exposing through Caddy/Tailscale.
ORKESTR_AUTH_REQUIRED=0
ORKESTR_COOKIE_SECURE=0
ORKESTR_CADDY_ENABLED=0
ORKESTR_PUBLIC_HTTPS_URL=
ORKESTR_TAILSCALE_HTTPS_NAME=
ORKESTR_SECURITY_RETURN_PAIRING_CODE=0

# Model/API settings.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Codex runtime inside the container.
CODEX_HOME=/data/codex
ORKESTR_CODEX_BIN=codex
ORKESTR_CODEX_SANDBOX=workspace-write
ORKESTR_CODEX_APPROVAL_POLICY=on-request
ORKESTR_RUNTIME_CODEX_COMMAND=codex --sandbox workspace-write --ask-for-approval on-request --no-alt-screen
ORKESTR_RUNTIME_WORKSPACE_ROOT=/workspace
ORKESTR_RUNTIME_SUBMIT_KEYS=C-m
ORKESTR_RUNTIME_SUBMIT_DELAY_MS=250
ORKESTR_WAKE_READY_TIMEOUT_MS=60000

# Browser/WhatsApp runtime.
ORKESTR_BROWSER_LAUNCH_DISABLED=1
ORKESTR_BROWSER_DESKTOP_MODE=disabled
ORKESTR_DEFAULT_DESKTOP_SLUG=desktop
ORKESTR_GMAIL_AUTH_DESKTOP_SLUG=gmail
ORKESTR_MANUAL_INTERVENTION_DESKTOP_SLUG=desktop
# WhatsApp uses Orkestr's integrated local bridge by default.
WHATSAPP_BRIDGE_MODE=local
ORKESTR_WHATSAPP_EXTERNAL_BRIDGE_ENABLED=0
WHATSAPP_BRIDGE_URL=

# Optional Gmail OAuth.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=
